# ── Database ──────────────────────────────────────────────────
# Local dev (SQLite):
DATABASE_URL=sqlite:///./data/ma_dd.db
# Production (Supabase PostgreSQL):
# DATABASE_URL=postgresql+psycopg://postgres:password@db.project.supabase.co:5432/postgres?sslmode=require
# Standalone PostgreSQL:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/ma_dd

# ── LLM Provider ──────────────────────────────────────────────
# Required: set at least one
GROQ_API_KEY=
# OPENAI_API_KEY=

# ── Encryption (optional) ─────────────────────────────────────
ENCRYPTION_KEY=
ENCRYPT_DOCUMENTS=false

# ── Authentication ────────────────────────────────────────────
AUTH_ENABLED=true
API_KEY=

# ── Email / SMTP (optional) ───────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFICATION_EMAIL=

# ── Branding ──────────────────────────────────────────────────
BRAND_NAME=M&A Due Diligence AI
FIRM_NAME=Your Law Firm
FIRM_EMAIL=contact@yourfirm.com
SUPPORT_EMAIL=support@yourfirm.com
FIRM_BASE_URL=http://localhost:3000

# ── DPDP (optional) ───────────────────────────────────────────
DPDP_COMPLIANCE=false
DATA_RESIDENCY=local

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# ── Misc ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
