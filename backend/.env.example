# =============================================================================
# M&A Due Diligence AI — Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Database ---
# SQLite (local dev):
# DATABASE_URL=sqlite:///./data/ma_dd.db
# PostgreSQL (production):
DATABASE_URL=postgresql+psycopg://user:password@host:5432/ma_dd

# --- LLM Provider ---
# Use Groq (free tier available):
GROQ_API_KEY=gsk-your-key-here
# GROQ_MODEL=llama-3.3-70b-versatile
# Or OpenAI:
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Encryption (AES-256 at rest) ---
# Generate key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=your-32-byte-base64-key-here
# ENCRYPT_DOCUMENTS=true

# --- Authentication ---
# AUTH_ENABLED=true
# Generate API key: python -c "import secrets; print(secrets.token_urlsafe(48))"
# API_KEY=your-api-key-here

# --- DPDP Act 2023 Compliance (India) ---
# DPDP_COMPLIANCE=true
# DATA_RESIDENCY=in

# --- CORS ---
# CORS_ORIGINS=["http://localhost:3000","https://your-app.railway.app"]

# --- Rate Limiting ---
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WINDOW=60

# --- Logging ---
# LOG_LEVEL=INFO
# DEBUG=false

# --- White-label Branding (for law firm resale) ---
# BRAND_NAME=M&A Due Diligence AI
# FIRM_NAME=Your Law Firm
# FIRM_EMAIL=contact@yourfirm.com
# SUPPORT_EMAIL=support@yourfirm.com

# --- Email Notifications (SendGrid / SMTP) ---
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.your-sendgrid-api-key
# SMTP_FROM=noreply@yourfirm.com
# NOTIFICATION_EMAIL=partner@lawfirm.com
